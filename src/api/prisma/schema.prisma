generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
enum PeriodType {
  weekly
  monthly
  custom
}
enum CategoryType {
  EXPENSE
  INCOME
}

model User {
  id         Int     @id @default(autoincrement())
  first_name String
  last_name  String
  email      String  @unique
  password   String
  photo      String?

  // Relations
  budgets       Budget[]
  alerts        Alert[]
  transactions  Transaction[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
  expiresAt DateTime

  @@map("refresh_tokens")
}

model Category {
  id    Int          @id @default(autoincrement())
  name  String
  color String?
  icon  String?
  type  CategoryType

  createdAt DateTime @default(now()) @map("created_at")  // nom DB préservé via @map
  updatedAt DateTime @updatedAt      @map("updated_at")

  transactions Transaction[]
  budgets      Budget[]
  alerts       Alert[]

  @@unique([name])
  @@map("category")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Decimal
  date        DateTime
  description String?
  userId      Int      @map("iduser")
  categoryId  Int      @map("idcategory")
  budgetId    Int?
  updatedAt   DateTime @default(now()) @updatedAt

  category Category  @relation(fields: [categoryId], references: [id])
  User     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  budget   Budget?   @relation(fields: [budgetId], references: [id])

  @@index([userId])
  @@index([userId, date])
  @@map("transactions")
}

model Budget {
  id           Int    @id @default(autoincrement())
  limit_amount Float
  period       PeriodType
  id_category  Int
  userId       Int

  // Relation avec l'utilisateur (un budget appartient à un utilisateur)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relation avec la catégorie (un budget concerne une catégorie)
  category Category @relation(fields: [id_category], references: [id])

  // Relation avec les transactions (un budget peut avoir plusieurs transactions)
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  @@index([userId])
  @@map("budgets")
}

model Alert {
  id             Int      @id @default(autoincrement())
  exceededAmount Decimal
  isRead         Boolean  @default(false)
  userId         Int
  categoryId     Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([userId])
  @@map("alerts")
}
